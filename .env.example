# Django
DJANGO_SECRET_KEY=change-me-in-production
DJANGO_DEBUG=True
DJANGO_ALLOWED_HOSTS=localhost,127.0.0.1,0.0.0.0

# PostgreSQL (used when running with Docker Compose)
POSTGRES_DB=reusable_kyc
POSTGRES_USER=postgres
POSTGRES_PASSWORD=postgres
POSTGRES_HOST=db
POSTGRES_PORT=5432

# CORS (frontend dev server)
CORS_ALLOWED_ORIGINS=http://localhost:5173,http://127.0.0.1:5173

# Blockchain integration
# For Docker-based local development: http://anvil:8545
# For local non-Docker development: http://localhost:8545
BLOCKCHAIN_RPC_URL=http://localhost:8545
ROLE_MANAGER_ADDRESS=
KYC_REGISTRY_ADDRESS=
CHAIN_ID=31337

# Foundry deployment
PRIVATE_KEY=your_deployer_private_key_here

PINATA_JWT=pinata_jwt_here
PINATA_API_KEY=pinata_api_key_here
PINATA_SECRET_KEY=pinata_secret_key_here
PINATA_GATEWAY=https://your-gateway-name.mypinata.cloud